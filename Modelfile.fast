# Ollama Modelfile for Gemma 4 E2B (fast inference settings)
#
# Usage:
#   ollama create gemma4-fast -f Modelfile.fast
#
# Before creating, download the GGUF files to ~/models/gemma4-demo/:
#   gemma-4-E2B-it.Q4_K_M.gguf     (2.45 GB)
#   gemma-4-E2B-it.BF16-mmproj.gguf (942 MB)

FROM ~/models/gemma4-demo/gemma-4-E2B-it.Q4_K_M.gguf
FROM ~/models/gemma4-demo/gemma-4-E2B-it.BF16-mmproj.gguf

TEMPLATE {{ .Prompt }}
RENDERER gemma4
PARSER gemma4

PARAMETER num_gpu 99
PARAMETER num_predict 128
PARAMETER num_ctx 2048
PARAMETER temperature 0.1
PARAMETER stop <turn|>
