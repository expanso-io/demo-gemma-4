# Gemma 4 × Expanso Edge — Environment Configuration
# Copy to .env and edit: cp .env.example .env

# ── Inference Server ─────────────────────────────────
INFERENCE_URL=http://localhost:8081     # llama.cpp server URL
LLAMA_PORT=8081                         # Port for start-server.sh

# ── Camera ───────────────────────────────────────────
# USB webcam (default): leave CAMERA_URL empty, set CAMERA_INDEX
# RTSP camera: set CAMERA_URL (CAMERA_INDEX is ignored)
CAMERA_URL=                             # e.g. rtsp://user:pass@192.168.2.10:554/stream
CAMERA_INDEX=0                          # USB camera device index
CAMERA_IFACE=en8                        # Network interface for IP cameras (Mac DHCP setup)

# ── Pipeline ─────────────────────────────────────────
CAPTURE_INTERVAL=5s                     # Time between frame captures
NODE_ID=edge-cam-001                    # Edge node identifier (appears in output)
PIPELINE_VERSION=2.0.0                  # Version tag in output envelope

# ── Frame Capture ────────────────────────────────────
CAPTURE_WIDTH=320                       # Frame width (pixels)
CAPTURE_HEIGHT=240                      # Frame height (pixels)
JPEG_QUALITY=70                         # JPEG compression quality (1-100)

# ── Dashboard ────────────────────────────────────────
PORT=9090                               # Dashboard web server port
DASHBOARD_URL=http://localhost:9090     # URL pipeline posts detections to
